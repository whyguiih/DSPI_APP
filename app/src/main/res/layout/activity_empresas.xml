<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/glassContainer"
        android:layout_width="0dp" android:layout_height="0dp"
        android:layout_margin="16dp" android:background="@drawable/bg_glass"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="EMPRESAS" android:textColor="#FFFFFF" android:textSize="28sp"
            android:fontFamily="@font/neo_sans"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp" android:layout_height="85dp"
        android:layout_marginHorizontal="16dp" android:layout_marginBottom="16dp"
        android:background="@drawable/bg_glass" android:orientation="horizontal"
        android:gravity="center" android:paddingHorizontal="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/btnInicio"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_inicio" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnProjetos"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_projetos" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Projetos" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnNai"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_nai" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nai" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnEmpresas"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp"
            android:background="@drawable/bg_active_bubble">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_empresas" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empresas" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnConta"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center" android:padding="8dp" android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_conta" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conta" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>