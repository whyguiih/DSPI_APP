<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/glassContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_glass"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbarThumbVertical="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageButton
                        android:id="@+id/btnVoltar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="#FFFFFF"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/txtTituloEmpresa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Detalhes da Empresa"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:fontFamily="@font/neo_sans"
                        android:gravity="center"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/btnVoltar"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginEnd="48dp"/> </androidx.constraintlayout.widget.ConstraintLayout>

                <ImageView
                    android:id="@+id/imgEmpresaLogo"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/ic_empresas"
                    app:tint="#FFFFFF"
                    android:background="@drawable/bg_input_glass"
                    android:padding="24dp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/tvNomeEmpresa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Indústrias Exemplo S.A."
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:fontFamily="@font/neo_sans"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/txtSetorEmpresa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Setor: Manufatura e Automação"
                    android:textColor="#B3FFFFFF"
                    android:textSize="14sp"
                    android:textAlignment="center"
                    android:fontFamily="@font/neo_sans"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sobre a Empresa"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/neo_sans"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/txtSobreEmpresa"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Somos líderes no desenvolvimento de soluções automatizadas para linhas de montagem industriais, sempre buscando inovação e integração tecnológica."
                    android:textColor="#E6FFFFFF"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="@font/neo_sans" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF"
                    android:layout_marginVertical="24dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Projetos vinculados"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/neo_sans"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:id="@+id/cardProjeto1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_input_glass"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desafio: Otimização de Sensores IoT"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/neo_sans"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Buscamos soluções para reduzir a latência de comunicação entre sensores."
                        android:textColor="#B3FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/neo_sans"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardProjeto2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_input_glass"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vaga: Estágio em Automação"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/neo_sans"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atuação direta na linha de montagem acompanhando engenheiros seniores."
                        android:textColor="#B3FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/neo_sans"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>