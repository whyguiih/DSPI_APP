<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/glassContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_glass"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/neo_sans"
            android:text="TABELAS"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <HorizontalScrollView
            android:id="@+id/tabScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/tvTitle">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView android:id="@+id/tabEquipe" style="@style/TabStyle" android:text="Equipe" />
                <TextView android:id="@+id/tabConhecimentos" style="@style/TabStyle" android:text="Conhecimentos" />
                <TextView android:id="@+id/tabRecursos" style="@style/TabStyle" android:text="Recursos" />
                <TextView android:id="@+id/tabCronograma" style="@style/TabStyle" android:text="Cronograma" />
                <TextView android:id="@+id/tabCanva" style="@style/TabStyle" android:text="Canva" />

                <TextView android:id="@+id/tabEmpresa" style="@style/TabStyle" android:text="Empresa" />
                <TextView android:id="@+id/tabPitch" style="@style/TabStyle" android:text="Pitch" />
                <TextView android:id="@+id/tabIA" style="@style/TabStyle" android:text="Uso de IA" />
                <TextView android:id="@+id/tabPlanilha" style="@style/TabStyle" android:text="Planilha" />
                <TextView android:id="@+id/tabComplementares" style="@style/TabStyle" android:text="Complementares" />
                <TextView android:id="@+id/tabCompletude" style="@style/TabStyle" android:text="Completude" />
                <TextView android:id="@+id/tabRelatorio" style="@style/TabStyle" android:text="Relatório" />
            </LinearLayout>
        </HorizontalScrollView>

        <ScrollView
            android:id="@+id/formScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintBottom_toTopOf="@id/btnEditarDados"
            app:layout_constraintTop_toBottomOf="@id/tabScrollView">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout android:id="@+id/formEquipe" style="@style/FormContainerStyle" android:visibility="visible">
                    <EditText android:id="@+id/etNomeEquipe" style="@style/InputGlassStyle" android:hint="Nome da equipe" />
                    <EditText android:id="@+id/etNomeProjeto" style="@style/InputGlassStyle" android:hint="Nome do projeto" />
                    <EditText android:id="@+id/etEmail" style="@style/InputGlassStyle" android:hint="E-mail" android:inputType="textEmailAddress" />
                    <EditText android:id="@+id/etAreaCurso" style="@style/InputGlassStyle" android:hint="Área de atuação do curso" />
                    <EditText android:id="@+id/etAreaProjeto" style="@style/InputGlassStyle" android:hint="Área de atuação do projeto" />
                    <EditText android:id="@+id/etNomeOrientador" style="@style/InputGlassStyle" android:hint="Nome do orientador" />
                    <EditText android:id="@+id/etNomeCoorientador" style="@style/InputGlassStyle" android:hint="Nome do coorientador" />
                    <EditText android:id="@+id/etIntegrante1" style="@style/InputGlassStyle" android:hint="Nome do integrante 1" />
                    <EditText android:id="@+id/etIntegrante2" style="@style/InputGlassStyle" android:hint="Nome do integrante 2" />
                    <EditText android:id="@+id/etIntegrante3" style="@style/InputGlassStyle" android:hint="Nome do integrante 3" />
                    <EditText android:id="@+id/etIntegrante4" style="@style/InputGlassStyle" android:hint="Nome do integrante 4" />
                    <EditText android:id="@+id/etIntegrante5" style="@style/InputGlassStyle" android:hint="Nome do integrante 5" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formConhecimentos" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/inputPlanoCurso" style="@style/InputGlassStyle" android:hint="Plano de curso" />
                    <EditText android:id="@+id/inputConhecimentos" style="@style/InputGlassStyle" android:hint="Conhecimentos aplicados" />
                    <EditText android:id="@+id/inputCapacidades" style="@style/InputGlassStyle" android:hint="Capacidades aplicadas" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formRecursos" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etRecursosFerramentas" style="@style/InputGlassStyle" android:hint="Ferramentas" />
                    <EditText android:id="@+id/etRecursosEquipamentos" style="@style/InputGlassStyle" android:hint="Equipamentos" />
                    <EditText android:id="@+id/etRecursosDescricao" style="@style/InputGlassStyle" android:hint="Descrição do produto" />
                    <EditText android:id="@+id/etRecursosQtdComprada" style="@style/InputGlassStyle" android:hint="Quantidade comprada" android:inputType="number" />
                    <EditText android:id="@+id/etRecursosQtdUtilizada" style="@style/InputGlassStyle" android:hint="Quantidade utilizada" android:inputType="number" />
                    <EditText android:id="@+id/etRecursosPrecoEstimado" style="@style/InputGlassStyle" android:hint="Preço estimado" android:inputType="numberDecimal" />
                    <EditText android:id="@+id/etRecursosUnidadeMedida" style="@style/InputGlassStyle" android:hint="Unidade de medida" />
                    <EditText android:id="@+id/etRecursosFornecedor" style="@style/InputGlassStyle" android:hint="Fornecedor principal" />
                    <EditText android:id="@+id/etRecursosModoObtencao" style="@style/InputGlassStyle" android:hint="Modo de obtenção" />
                    <EditText android:id="@+id/etRecursosDisponibilidade" style="@style/InputGlassStyle" android:hint="Disponibilidade" />
                    <EditText android:id="@+id/etRecursosPagamento" style="@style/InputGlassStyle" android:hint="Pagamento" />
                    <EditText android:id="@+id/etRecursosAlternativas" style="@style/InputGlassStyle" android:hint="Alternativas consideradas" />
                    <EditText android:id="@+id/etRecursosPrecoTotal" style="@style/InputGlassStyle" android:hint="Preço total" android:inputType="numberDecimal" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formCronograma" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etCronoProcesso" style="@style/InputGlassStyle" android:hint="Processo" />
                    <EditText android:id="@+id/etCronoEtapas" style="@style/InputGlassStyle" android:hint="Etapas" />
                    <EditText android:id="@+id/etCronoResponsavel" style="@style/InputGlassStyle" android:hint="Responsável" />
                    <EditText android:id="@+id/etCronoDataInicio" style="@style/InputGlassStyle" android:hint="Data de início" android:inputType="date" />
                    <EditText android:id="@+id/etCronoDataFinal" style="@style/InputGlassStyle" android:hint="Data final" android:inputType="date" />
                    <EditText android:id="@+id/etCronoObservacoes" style="@style/InputGlassStyle" android:hint="Observações" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formCanva" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etCanvaAtividadesChaves" style="@style/InputGlassStyle" android:hint="Atividades chaves" />
                    <EditText android:id="@+id/etCanvaPropostaChave" style="@style/InputGlassStyle" android:hint="Proposta chave" />
                    <EditText android:id="@+id/etCanvaRelacionamentoClientes" style="@style/InputGlassStyle" android:hint="Relacionamentos com clientes" />
                    <EditText android:id="@+id/etCanvaSegmentosClientes" style="@style/InputGlassStyle" android:hint="Segmentos de clientes" />
                    <EditText android:id="@+id/etCanvaRecursosChaves" style="@style/InputGlassStyle" android:hint="Recursos chaves" />
                    <EditText android:id="@+id/etCanvaCanais" style="@style/InputGlassStyle" android:hint="Canais" />
                    <EditText android:id="@+id/etCanvaEstruturaCustos" style="@style/InputGlassStyle" android:hint="Estrutura de custos" />
                    <EditText android:id="@+id/etCanvaFluxoReceita" style="@style/InputGlassStyle" android:hint="Fluxo de receita" />
                    <EditText android:id="@+id/etCanvaParceirosChaves" style="@style/InputGlassStyle" android:hint="Parceiros chaves" />

                </LinearLayout>


                <LinearLayout android:id="@+id/formEmpresa" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etEmpresaNome" style="@style/InputGlassStyle" android:hint="Nome da Empresa" />
                    <EditText android:id="@+id/etEmpresaCnpj" style="@style/InputGlassStyle" android:hint="CNPJ" android:inputType="number" />
                    <EditText android:id="@+id/etEmpresaRegiao" style="@style/InputGlassStyle" android:hint="Região" />
                    <EditText android:id="@+id/etEmpresaTelefone" style="@style/InputGlassStyle" android:hint="Telefone de Contato" />
                    <EditText android:id="@+id/etEmpresaEmail" style="@style/InputGlassStyle" android:hint="Email de Contato" />
                    <EditText android:id="@+id/etEmpresaObjetivos" style="@style/InputGlassStyle" android:hint="Objetivos" />
                    <EditText android:id="@+id/etEmpresaProblema" style="@style/InputGlassStyle" android:hint="Problema do projeto" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formPitch" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etPitchRoteiro" style="@style/InputGlassStyle" android:hint="Roteiro do Pitch" android:lines="5" android:gravity="top|start" />
                    <Button android:id="@+id/btnUploadVideo" style="@style/InputGlassStyle" android:layout_width="match_parent" android:layout_height="56dp" android:text="Upload do Vídeo do Pitch" android:textColor="#FFFFFF" android:layout_marginTop="16dp" />
                    <ProgressBar android:id="@+id/pbVideoUpload" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:visibility="gone" android:progressTint="#FFFFFF" android:indeterminate="false" />

                    <FrameLayout
                        android:id="@+id/videoContainer"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="16dp"
                        android:visibility="gone"
                        android:background="@drawable/bg_glass">

                        <VideoView
                            android:id="@+id/vvPitch"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center" />

                        <!-- NOVO: Spinner de carregamento -->
                        <ProgressBar
                            android:id="@+id/pbVideoBuffer"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="#FFFFFF"
                            android:visibility="gone" />

                        <!-- Camada de controles customizados -->
                        <LinearLayout
                            android:id="@+id/videoControls"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:orientation="vertical"
                            android:background="#88000000"
                            android:padding="8dp">

                            <SeekBar
                                android:id="@+id/videoSeekBar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:progressTint="#FFFFFF"
                                android:thumbTint="#FFFFFF" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="horizontal">

                                <ImageButton
                                    android:id="@+id/btnRewind"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_rew"
                                    app:tint="#FFFFFF"
                                    android:contentDescription="Voltar 10s" />

                                <ImageButton
                                    android:id="@+id/btnPlayPause"
                                    android:layout_width="56dp"
                                    android:layout_height="56dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_play"
                                    app:tint="#FFFFFF"
                                    android:contentDescription="Play/Pause" />

                                <ImageButton
                                    android:id="@+id/btnForward"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:src="@android:drawable/ic_media_ff"
                                    app:tint="#FFFFFF"
                                    android:contentDescription="Avançar 10s" />

                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>

                    <TextView android:id="@+id/tvVideoStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:layout_marginTop="8dp" android:text="Nenhum vídeo enviado" android:gravity="center" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formIA" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etIaNomeFerramenta" style="@style/InputGlassStyle" android:hint="Nome da ferramenta" />
                    <EditText android:id="@+id/etIaLinkAcesso" style="@style/InputGlassStyle" android:hint="Link de acesso" android:inputType="textUri" />
                    <EditText android:id="@+id/etIaTipoLicenca" style="@style/InputGlassStyle" android:hint="Tipo de licença utilizada" />
                    <EditText android:id="@+id/etIaEtapaUso" style="@style/InputGlassStyle" android:hint="Etapa de uso durante o projeto" />
                    <EditText android:id="@+id/etIaCriacaoPrompt" style="@style/InputGlassStyle" android:hint="Criação (prompt, etc)" />
                    <EditText android:id="@+id/etIaDescricaoUso" style="@style/InputGlassStyle" android:hint="Descreva como foi utilizada" android:lines="3" />
                </LinearLayout>

                <LinearLayout android:id="@+id/formPlanilha" style="@style/FormContainerStyle" android:visibility="gone">
                    <EditText android:id="@+id/etPlanilhaTarefas" style="@style/InputGlassStyle" android:hint="Tarefas" />
                    <EditText android:id="@+id/etPlanilhaAlunoResponsavel" style="@style/InputGlassStyle" android:hint="Aluno responsável" />
                    <EditText android:id="@+id/etPlanilhaProfessorArea" style="@style/InputGlassStyle" android:hint="Professor da área" />
                    <EditText android:id="@+id/etPlanilhaInicioPrevisto" style="@style/InputGlassStyle" android:hint="Início previsto" android:inputType="date" />
                    <EditText android:id="@+id/etPlanilhaFimPrevisto" style="@style/InputGlassStyle" android:hint="Fim previsto" android:inputType="date" />
                    <EditText android:id="@+id/etPlanilhaInicioRealizado" style="@style/InputGlassStyle" android:hint="Início realizado" android:inputType="date" />
                    <EditText android:id="@+id/etPlanilhaFimRealizado" style="@style/InputGlassStyle" android:hint="Fim realizado" android:inputType="date" />
                    <EditText android:id="@+id/etPlanilhaDuracaoDias" style="@style/InputGlassStyle" android:hint="Duração (dias)" android:inputType="number" />
                    <Spinner
                        android:id="@+id/spPlanilhaStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/etPlanilhaDescricao" style="@style/InputGlassStyle" android:hint="Descrição da tarefa" />
                    <EditText android:id="@+id/etPlanilhaDificuldades" style="@style/InputGlassStyle" android:hint="Dificuldades enxergadas" />
                    <EditText android:id="@+id/etPlanilhaImpacto" style="@style/InputGlassStyle" android:hint="Impacto nas outras tarefas" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/formComplementares"
                    style="@style/FormContainerStyle"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/etComplUnidade"
                        style="@style/InputGlassStyle"
                        android:hint="Unidade (Nome Comercial)" />

                    <EditText
                        android:id="@+id/etComplCoordenador"
                        style="@style/InputGlassStyle"
                        android:hint="Coordenador Pedagógico" />

                    <EditText
                        android:id="@+id/etComplGestor"
                        style="@style/InputGlassStyle"
                        android:hint="Gestor" />

                    <EditText
                        android:id="@+id/etComplEmpresa"
                        style="@style/InputGlassStyle"
                        android:hint="Empresa" />

                    <EditText
                        android:id="@+id/etComplProjeto"
                        style="@style/InputGlassStyle"
                        android:hint="Projeto" />

                    <EditText
                        android:id="@+id/etComplDescricao"
                        style="@style/InputGlassStyle"
                        android:hint="Descrição"
                        android:gravity="top|start"
                        android:minLines="4"
                        android:inputType="textMultiLine"/>

                </LinearLayout>

                <LinearLayout android:id="@+id/formCompletude" style="@style/FormContainerStyle" android:visibility="gone">

                    <EditText android:id="@+id/etCompleQuantidade" style="@style/InputGlassStyle" android:hint="Quantidade" android:inputType="number" />
                    <EditText android:id="@+id/etCompleIdentificacao" style="@style/InputGlassStyle" android:hint="Equipe / Unidade / Empresa" />
                    <EditText android:id="@+id/etCompleResponsavel" style="@style/InputGlassStyle" android:hint="Responsável pelo preenchimento" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Dados da Equipe" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusEquipe" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Conhecimentos" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusConhecimento" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Recursos Aplicados" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusRecursos" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Canvas Preencher" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusCanvas" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Pitch Escrito" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusPitchEscrito" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Pitch Vídeo" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusPitchVideo" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Cronograma" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusCronograma" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Foto Equipe" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusFotoEquipe" android:layout_width="match_parent" android:layout_height="wrap_content" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Fotos Etapa Projeto" android:textColor="#FFFFFF" />
                    <Spinner android:id="@+id/spCompleStatusFotosEtapa" android:layout_width="match_parent" android:layout_height="wrap_content" />

                </LinearLayout>

                <LinearLayout android:id="@+id/formRelatorio" style="@style/FormContainerStyle" android:visibility="gone">

                    <EditText android:id="@+id/etRelNomeEmpresa" style="@style/InputGlassStyle" android:hint="Nome da Empresa" />
                    <EditText android:id="@+id/etRelEmailEmpresa" style="@style/InputGlassStyle" android:hint="Email da Empresa" />
                    <EditText android:id="@+id/etRelSetorEmpresa" style="@style/InputGlassStyle" android:hint="Setor da Empresa" />
                    <EditText android:id="@+id/etRelDescricao" style="@style/InputGlassStyle" android:hint="Descrição" />
                    <EditText android:id="@+id/etRelRoteiroPitch" style="@style/InputGlassStyle" android:hint="Roteiro do Pitch" />
                    <EditText android:id="@+id/etRelIntegrante1" style="@style/InputGlassStyle" android:hint="Integrante 1" />
                    <EditText android:id="@+id/etRelIntegrante2" style="@style/InputGlassStyle" android:hint="Integrante 2" />
                    <EditText android:id="@+id/etRelIntegrante3" style="@style/InputGlassStyle" android:hint="Integrante 3" />
                    <EditText android:id="@+id/etRelIntegrante4" style="@style/InputGlassStyle" android:hint="Integrante 4" />
                    <EditText android:id="@+id/etRelIntegrante5" style="@style/InputGlassStyle" android:hint="Integrante 5" />
                    <EditText android:id="@+id/etRelOrientador" style="@style/InputGlassStyle" android:hint="Orientador" />
                    <EditText android:id="@+id/etRelCoorientador" style="@style/InputGlassStyle" android:hint="Coorientador" />
                    <EditText android:id="@+id/etRelNomeProjeto" style="@style/InputGlassStyle" android:hint="Nome do Projeto" />
                    <EditText android:id="@+id/etRelNomeEquipe" style="@style/InputGlassStyle" android:hint="Nome da Equipe" />
                    <EditText android:id="@+id/etRelAreaAtuProjeto" style="@style/InputGlassStyle" android:hint="Área de Atuação do Projeto" />
                    <EditText android:id="@+id/etRelAreaAtuCurso" style="@style/InputGlassStyle" android:hint="Área de Atuação do Curso" />
                    <EditText android:id="@+id/etRelUnidadeSenai" style="@style/InputGlassStyle" android:hint="Unidade SENAI" />
                    <EditText android:id="@+id/etRelGestor" style="@style/InputGlassStyle" android:hint="Gestor" />
                    <EditText android:id="@+id/etRelFerramentaIA" style="@style/InputGlassStyle" android:hint="Ferramenta de IA" />
                    <EditText android:id="@+id/etRelLinkAcesso" style="@style/InputGlassStyle" android:hint="Link de Acesso" />
                    <EditText android:id="@+id/etRelLicenca" style="@style/InputGlassStyle" android:hint="Licença" />
                    <EditText android:id="@+id/etRelEtapaUso" style="@style/InputGlassStyle" android:hint="Etapa de Uso" />
                    <EditText android:id="@+id/etRelPrompt" style="@style/InputGlassStyle" android:hint="Prompt" />
                    <EditText android:id="@+id/etRelMotivoUso" style="@style/InputGlassStyle" android:hint="Motivo de Uso" />
                    <EditText android:id="@+id/etRelFerramentasProj" style="@style/InputGlassStyle" android:hint="Ferramentas do Projeto" />
                    <EditText android:id="@+id/etRelEquipamentosProj" style="@style/InputGlassStyle" android:hint="Equipamentos do Projeto" />
                    <EditText android:id="@+id/etRelQuantCompra" style="@style/InputGlassStyle" android:hint="Quantidade de Compra" />
                    <EditText android:id="@+id/etRelQuantUtilizada" style="@style/InputGlassStyle" android:hint="Quantidade Utilizada" />
                    <EditText android:id="@+id/etRelPreco" style="@style/InputGlassStyle" android:hint="Preço" />
                    <EditText android:id="@+id/etRelFornecedor" style="@style/InputGlassStyle" android:hint="Fornecedor" />
                    <EditText android:id="@+id/etRelModoObtencao" style="@style/InputGlassStyle" android:hint="Modo de Obtenção" />
                    <EditText android:id="@+id/etRelProcessamento" style="@style/InputGlassStyle" android:hint="Processamento" />
                    <EditText android:id="@+id/etRelAlternativaUso" style="@style/InputGlassStyle" android:hint="Alternativa de Uso" />
                    <EditText android:id="@+id/etRelQuantUtilizada2" style="@style/InputGlassStyle" android:hint="Quantidade Utilizada 2" />
                    <EditText android:id="@+id/etRelFormaPagamento" style="@style/InputGlassStyle" android:hint="Forma de Pagamento" />
                    <EditText android:id="@+id/etRelPrecoTotal" style="@style/InputGlassStyle" android:hint="Preço Total" />

                    <Button
                        android:id="@+id/btnGerarRelatorio"
                        style="@style/InputGlassStyle"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="Gerar Relatório PDF"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnAcaoCanvaRelatorio"
                        style="@style/InputGlassStyle"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="Gerar Canva"
                        android:textColor="#FFFFFF"
                        android:visibility="gone" />


                    <Button
                        android:id="@+id/btnVisualizarRelatorio"
                        style="@style/InputGlassStyle"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:text="Abrir PDF do Relatório"
                        android:textColor="#FFFFFF"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnEditarDados"
            style="@style/InputGlassStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="8dp"
            android:fontFamily="@font/neo_sans"
            android:text="Editar Dados"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <include
        android:id="@+id/bottomNavigationContainer"
        layout="@layout/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>