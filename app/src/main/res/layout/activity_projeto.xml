<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_button_glass"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvItemNomeProjeto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/neo_sans_bold_italic"
        android:textColor="#FFFFFF"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tvItemStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/neo_sans"
        android:textColor="#B3FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvItemEquipe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/neo_sans"
        android:textColor="#E6FFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvBadgePitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_login"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="▶ PITCH DISPONÍVEL"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />
</LinearLayout>