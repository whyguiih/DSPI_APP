<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavigationContainer"
    android:layout_width="match_parent"
    android:layout_height="85dp"
    android:background="@drawable/bg_glass"
    android:paddingHorizontal="8dp"
    android:paddingVertical="8dp">

    <View android:id="@+id/activeBubble" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/bg_active_bubble" />

    <LinearLayout android:id="@+id/bottomNavLayout" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center">

        <LinearLayout android:id="@+id/btnInicio" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_inicio" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Início" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnProjetos" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_projetos" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Projetos" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnNai" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/ic_mia" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MIA" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnEmpresas" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_empresas" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Empresas" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/btnConta" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_conta" app:tint="#FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conta" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="@font/neo_sans" android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>