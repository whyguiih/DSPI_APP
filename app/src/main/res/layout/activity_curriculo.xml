<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="32dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cadastroGlassContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="32dp"
                android:padding="32dp"
                android:background="@drawable/bg_glass"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/logoCadastro"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:src="@drawable/logo_integra"
                    android:layout_marginBottom="24dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/txtCrieCurriculo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preencha seu curriculo"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/neo_sans"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/logoCadastro"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <EditText
                    android:id="@+id/inputNome"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Nome Completo"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/txtCrieCurriculo" />

                <EditText
                    android:id="@+id/inputEmailCadastro"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="E-mail Institucional ou Pessoal"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textEmailAddress"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputNome" />

                <EditText
                    android:id="@+id/inputDataNascimento"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Data de Nascimento (DD/MM/AAAA)"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="date"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputEmailCadastro" />

                <EditText
                    android:id="@+id/inputTelefone"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Telefone de contato"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="phone"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputDataNascimento" />

                <EditText
                    android:id="@+id/inputCidade"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Cidade em realizou as atividades"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputTelefone" />

                <EditText
                    android:id="@+id/inputProjeto"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Projeto ao qual está vinculado"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputCidade" />

                <EditText
                    android:id="@+id/inputEmpresa"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Empresa ao qual o projeto está vinculado:"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputProjeto" />

                <EditText
                    android:id="@+id/inputHabilidade"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Habilidades"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputEmpresa" />

                <EditText
                    android:id="@+id/inputOQueFez"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="O que desenvolvi no projeto"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputHabilidade" />

                <EditText
                    android:id="@+id/inputMotivo"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Motivo de participar do projeto."
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputOQueFez" />

                <EditText
                    android:id="@+id/inputAprendo"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Aprendo mais:"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputMotivo" />

                <EditText
                    android:id="@+id/inputPrefiroTrabalhar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:hint="Prefiro trabalhar de que forma:"
                    android:textColorHint="#B3FFFFFF"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:paddingHorizontal="20dp"
                    android:inputType="textPersonName"
                    android:fontFamily="@font/neo_sans"
                    app:layout_constraintTop_toBottomOf="@id/inputAprendo" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCadastrar"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_button_login"
                    android:text="CADASTRAR"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/neo_sans"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    app:layout_constraintTop_toBottomOf="@id/inputPrefiroTrabalhar" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/btnCadastrar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">


                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
